{
  "hosting": {
    "site": "geo-flag",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/geo-stats-map",
        "destination": "/geo-stats-map.html"
      },
      {
        "source": "/geo-stats-map/**",
        "destination": "/geo-stats-map.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
